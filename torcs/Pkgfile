# Description: The Open Racing Car Simulator
# URL: https://torcs.sourceforge.net/
# Maintainer: Jose Beneyto, sepen at crux-arm dot nu
# Depends on: freeglut freealut plib

name=torcs
version=1.3.9
release=1
source=(https://sourceforge.net/projects/torcs/files/all-in-one/1.3.9/torcs-1.3.9.tar.bz2)

build() {
    cd $name-$version

    ./configure \
        --prefix=/usr 

    make -j1

    make DESTDIR=$PKG install
    make DESTDIR=$PKG datainstall
}
