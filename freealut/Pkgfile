# Description: OpenAL Utility Toolkit (ALUT)
# URL: https://www.openal.org
# Maintainer: Jose Beneyto, sepen at crux-arm dot nu
# Depends on: openal

name=freealut
version=1.1.0
release=1
source=(https://github.com/vancegroup/${name}/archive/refs/tags/${name}_1_1_0.tar.gz)

build() {
    cd ${name}-${name}_1_1_0

    autoreconf -fi
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static

    make
    make DESTDIR=$PKG install
}
